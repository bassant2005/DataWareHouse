  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Expire Changed Records"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="T2"
      DTS:DTSID="{1D09134D-73AB-4B25-A537-BFCB8433A1F7}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Expire Changed Records"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{71AF0E33-8F95-446A-97A1-435208275F8C}"
          SQLTask:SqlStatementSource="UPDATE Campaign_Q2_Target&#xA;SET End_Date = CAST(GETDATE() AS DATE), Is_Current = 0&#xA;WHERE Is_Current = 1&#xA;AND ID IN (&#xA;    SELECT s.ID &#xA;    FROM Campaign_Q2 s&#xA;    JOIN Campaign_Q2_Target t ON s.ID = t.ID AND t.Is_Current = 1&#xA;    WHERE s.Name &lt;&gt; t.Name OR s.Budget &lt;&gt; t.Budget&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Insert New Records"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="T1"
      DTS:DTSID="{F4720093-64AE-4F2A-9B55-CAFEB38AB9C9}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Insert New Records"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{71AF0E33-8F95-446A-97A1-435208275F8C}"
          SQLTask:SqlStatementSource="INSERT INTO Campaign_Q2_Target &#xA;    (ID, Name, Budget, Current_Name, Current_Budget, &#xA;     Start_Date, End_Date, Is_Current, Update_Date)&#xA;SELECT &#xA;    s.ID, s.Name, s.Budget, s.Name, s.Budget,&#xA;    s.Update_Date, NULL, 1, s.Update_Date&#xA;FROM Campaign_Q2 s&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 FROM Campaign_Q2_Target t WHERE t.ID = s.ID&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Insert New Version"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="T3"
      DTS:DTSID="{389DDDF7-6B20-4623-BEEF-8152E49C67C3}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Insert New Version"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{71AF0E33-8F95-446A-97A1-435208275F8C}"
          SQLTask:SqlStatementSource="INSERT INTO Campaign_Q2_Target &#xA;    (ID, Name, Budget, Current_Name, Current_Budget,&#xA;     Start_Date, End_Date, Is_Current, Update_Date)&#xA;SELECT &#xA;    s.ID, s.Name, s.Budget, s.Name, s.Budget,&#xA;    s.Update_Date, NULL, 1, s.Update_Date&#xA;FROM Campaign_Q2 s&#xA;WHERE EXISTS (&#xA;    SELECT 1 FROM Campaign_Q2_Target t &#xA;    WHERE t.ID = s.ID AND t.Is_Current = 0&#xA;)&#xA;AND NOT EXISTS (&#xA;    SELECT 1 FROM Campaign_Q2_Target t &#xA;    WHERE t.ID = s.ID AND t.Is_Current = 1&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Update Current Columns"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="T4"
      DTS:DTSID="{4CE65A03-FC2B-406B-9254-0BC7789B9915}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update Current Columns"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{71AF0E33-8F95-446A-97A1-435208275F8C}"
          SQLTask:SqlStatementSource="UPDATE Campaign_Q2_Target&#xA;SET Current_Name = s.Name, Current_Budget = s.Budget&#xA;FROM Campaign_Q2_Target t&#xA;JOIN Campaign_Q2 s ON t.ID = s.ID" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
