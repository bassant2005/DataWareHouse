  DTS:VersionBuild="5"
  DTS:VersionGUID="{3FCE35DC-7E6A-4AE1-BB1A-291674ACDA50}">
  <DTS:Property
    DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:ConnectionManagers>
    <DTS:ConnectionManager
      DTS:refId="Package.ConnectionManagers[.\SQLEXPRESS.AirQualityDB]"
      DTS:CreationName="OLEDB"
      DTS:DTSID="{866AC5E3-6E22-4613-BB00-D9ABEADA35DA}"
      DTS:ObjectName=".\SQLEXPRESS.AirQualityDB">
      <DTS:ObjectData>
        <DTS:ConnectionManager
          DTS:ConnectRetryCount="1"
          DTS:ConnectRetryInterval="5"
          DTS:ConnectionString="Data Source=.\SQLEXPRESS;Initial Catalog=AirQualityDB;Provider=MSOLEDBSQL.1;Integrated Security=SSPI;Application Name=SSIS-Package1-{866AC5E3-6E22-4613-BB00-D9ABEADA35DA}.\SQLEXPRESS.AirQualityDB;Auto Translate=False;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Aggregate &amp; Insert"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="T3"
      DTS:DTSID="{C5A7FA26-6323-4EDC-A2B8-3B0E52134EBD}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Aggregate &amp; Insert"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{866AC5E3-6E22-4613-BB00-D9ABEADA35DA}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE Trader_Summary;&#xA;&#xA;INSERT INTO Trader_Summary (Trader_ID, Trade_Date, Total_Buy, Total_Sell)&#xA;SELECT &#xA;    a.Trader_ID,&#xA;    a.Trade_Date,&#xA;    ISNULL(b.Total_Buy, 0),&#xA;    ISNULL(s.Total_Sell, 0)&#xA;FROM (SELECT DISTINCT Trader_ID, Trade_Date FROM Cleaned_Trades) a&#xA;LEFT JOIN (&#xA;    SELECT Trader_ID, Trade_Date, SUM(Qty) AS Total_Buy&#xA;    FROM Cleaned_Trades WHERE Action_Clean = 'buy'&#xA;    GROUP BY Trader_ID, Trade_Date&#xA;) b ON a.Trader_ID = b.Trader_ID AND a.Trade_Date = b.Trade_Date&#xA;LEFT JOIN (&#xA;    SELECT Trader_ID, Trade_Date, SUM(Qty) AS Total_Sell&#xA;    FROM Valid_Sells&#xA;    GROUP BY Trader_ID, Trade_Date&#xA;) s ON a.Trader_ID = s.Trader_ID AND a.Trade_Date = s.Trade_Date&#xA;ORDER BY a.Trader_ID;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Clean"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="T1"
      DTS:DTSID="{34FF5712-7B0E-467F-90A8-7C2DED6F0BDD}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Clean"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{866AC5E3-6E22-4613-BB00-D9ABEADA35DA}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE Cleaned_Trades;&#xA;&#xA;INSERT INTO Cleaned_Trades&#xA;SELECT&#xA;    Trader_ID,&#xA;    CAST(Trade_TS AS DATE) AS Trade_Date,&#xA;    Trade_TS,&#xA;    CASE &#xA;        WHEN Quantity &lt; 0 AND LOWER(Action) = 'buy'  THEN 'sell'&#xA;        WHEN Quantity &lt; 0 AND LOWER(Action) = 'sell' THEN 'buy'&#xA;        ELSE LOWER(Action)&#xA;    END AS Action_Clean,&#xA;    ABS(Quantity) AS Qty&#xA;FROM raw_trades&#xA;WHERE LOWER(Action) IN ('buy','sell')&#xA;  AND Trader_ID IS NOT NULL&#xA;  AND Quantity != 0&#xA;GROUP BY&#xA;    Trader_ID,&#xA;    CAST(Trade_TS AS DATE),&#xA;    Trade_TS,&#xA;    CASE &#xA;        WHEN Quantity &lt; 0 AND LOWER(Action) = 'buy'  THEN 'sell'&#xA;        WHEN Quantity &lt; 0 AND LOWER(Action) = 'sell' THEN 'buy'&#xA;        ELSE LOWER(Action)&#xA;    END,&#xA;    ABS(Quantity);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Validate Sells"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="T2"
      DTS:DTSID="{3460718F-5E92-4E0D-B4C3-06A22A93A04B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Validate Sells"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{866AC5E3-6E22-4613-BB00-D9ABEADA35DA}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE Valid_Sells;&#xA;&#xA;INSERT INTO Valid_Sells&#xA;SELECT s.Trader_ID, s.Trade_Date, s.Qty&#xA;FROM Cleaned_Trades s&#xA;WHERE s.Action_Clean = 'sell'&#xA;  AND EXISTS (&#xA;      SELECT 1 &#xA;      FROM Cleaned_Trades b&#xA;      WHERE b.Trader_ID  = s.Trader_ID&#xA;        AND b.Trade_Date = s.Trade_Date&#xA;        AND b.Action_Clean = 'buy'&#xA;        AND b.Trade_TS   &lt; s.Trade_TS&#xA;        AND b.Qty        &gt;= s.Qty&#xA;  );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Constraint]"
      DTS:CreationName=""
      DTS:DTSID="{0B06EB33-1FB6-4812-9F71-D66A69A60DD0}"
      DTS:From="Package\Clean"
      DTS:LogicalAnd="True"
      DTS:ObjectName="Constraint"
      DTS:To="Package\Validate Sells" />
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Constraint 1]"
      DTS:CreationName=""
      DTS:DTSID="{935E2915-7C71-4B0D-97ED-E867B86532BF}"
      DTS:From="Package\Validate Sells"
      DTS:LogicalAnd="True"
      DTS:ObjectName="Constraint 1"
      DTS:To="Package\Aggregate &amp; Insert" />
  </DTS:PrecedenceConstraints>
