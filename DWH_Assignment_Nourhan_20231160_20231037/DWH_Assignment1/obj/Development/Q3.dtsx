      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{DBC3D517-2846-4A0A-8A22-52A6F26E3C5D}"
          SQLTask:SqlStatementSource="SELECT &#xA;    CASE &#xA;        WHEN (SELECT MAX(Schedule_Date) FROM Device_Status) &gt; ISNULL(MAX(Insert_Date), '1900-01-01') THEN 1&#xA;        ELSE ISNULL(MAX(Version_No), 0) + 1 &#xA;    END AS NewVersion&#xA;FROM Device_Status_History;"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="NEWversion"
            SQLTask:DtsVariableName="User::NewVersion" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
