                    <arrayElement
                      dataType="System.String"><![CDATA[using System;
using System.Collections.Generic;
using System.Net;
using System.Web.Script.Serialization;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPoint]
public class ScriptMain : UserComponent
{
    public override void CreateNewOutputRows()
    {
        try
        {
            // Fix TLS
            ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls12;

            string url = "https://69be08c917c3d7d977910f4e.mockapi.io/us_air_quality/air_monitoring";

            WebClient client = new WebClient();
            string json = client.DownloadString(url);

            JavaScriptSerializer js = new JavaScriptSerializer();
            var data = js.Deserialize<List<Dictionary<string, object>>>(json);

            foreach (var item in data)
            {
                Output0Buffer.AddRow();

                Output0Buffer.id = item["id"].ToString();
                Output0Buffer.city = item["location"].ToString();
                Output0Buffer.timestamp = Convert.ToDateTime(item["timestamp"]);

                Output0Buffer.pm25 = Convert.ToSingle(item["pm25"]);
                Output0Buffer.pm10 = Convert.ToSingle(item["pm10"]);

                Output0Buffer.source = "API";
            }
        }
        catch (Exception ex)
        {
            bool fireAgain = false;
            ComponentMetaData.FireError(0, "SCRIPT ERROR", ex.Message, "", 0, out fireAgain);
        }
    }
}]]></arrayElement>
